      "bug_class": "version-lineage-mismatch",
      "surface": "durable-write-sequences",
      "evidence": "competence_gate_report.challenge.005",
      "expected_error": "implementing: ready replay must use ready_payload_inner_version"
    },
    {
      "id": "006-ready-dependency-partition-boundary",
      "challenge_id": "006",
      "bug_class": "partition-boundary",
      "surface": "liveness-responsibility-maps",
      "evidence": "competence_gate_report.challenge.006",
      "production_evidence_path": "libraries/devloop/restart_responsibility_contract.lua",
      "production_evidence": "invariant #6 forbids dependency release_gate defer on actionable ready",
      "expected_error": "ready: invariant #6 forbids dependency release_gate defer on actionable ready",
      "mutation_required": true
    },
    {
      "id": "007-partial-write-idempotency-completeness",
