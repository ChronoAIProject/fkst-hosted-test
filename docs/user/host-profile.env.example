# Copy to ${XDG_CONFIG_HOME:-$HOME/.config}/fkst/host.env and edit for this machine.
# This file is a host-local shell environment scaffold. Do not commit the filled copy.

# Shared fkst-framework binary built from fkst-substrate.
BIN=/path/to/fkst-substrate/target/debug/fkst-framework

# The host repository being supervised and the fkst-packages checkout that supplies
# the shared runner plus platform packages.
FKST_HOST_ROOT=/path/to/host-repo
FKST_PLATFORM_ROOT=/path/to/fkst-packages

# Host-stable durable delivery and external-command rate-pool roots. Keep the durable
# root separate from runtime scratch; the shared host runner creates fresh runtime
# scratch by default.
FKST_DURABLE_ROOT=/path/to/host-stable/durable
FKST_RATE_POOL_ROOT=/path/to/host-stable/rate-pools
FKST_RATE_POOL_GH=50,50

# GitHub posture and repository identity. FKST_GITHUB_WRITE=1 is the only real-write
# posture; unset or any other value is dry-run.
FKST_GITHUB_REPO=owner/repo
# FKST_GITHUB_WRITE=1
FKST_GITHUB_BOT_LOGIN=this-host-bot-login
FKST_GITHUB_PROXY_POLL_LABEL_PREFIX=fkst-dev:

# github-devloop per-device topology.
FKST_DEVLOOP_UPSTREAM_BRANCH=dev
FKST_DEVLOOP_INTEGRATION_BRANCH=integration-this-host-bot-login
FKST_DEVLOOP_ROLLUP_MERGE=auto

# Optional: skip local BIN freshness builds when another process manages the build.
# FKST_NO_AUTOBUILD=1
